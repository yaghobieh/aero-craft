{
  "name": "@forgedevstack/aerocraft",
  "version": "1.0.4",
  "description": "Composable shortcut utility classes for CSS. PostCSS plugin with configurable prefix and standalone output.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./postcss": {
      "types": "./dist/postcss/index.d.ts",
      "import": "./dist/postcss/index.js",
      "require": "./dist/postcss/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "aerocraft": "./bin/aerocraft.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "npx tsc && npx vite build && npm run build:css",
    "build:css": "node scripts/build-css.mjs",
    "prepare": "echo 'skipping prepare for local dev'",
    "lint": "eslint . --ext ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "glob": "^10.4.5"
  },
  "peerDependencies": {
    "postcss": ">=8.0.0",
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "postcss": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.14",
    "postcss": "^8.4.49",
    "react": "^19.2.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  },
  "keywords": [
    "css",
    "utilities",
    "shortcuts",
    "postcss",
    "composition",
    "forgestack",
    "aerocraft"
  ],
  "author": "John Yaghobieh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaghobieh/aero-craft.git"
  },
  "bugs": {
    "url": "https://github.com/yaghobieh/aero-craft/issues"
  },
  "homepage": "https://aerocraftjs.com"
}

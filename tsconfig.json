{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@types/*": ["src/types/*"],
      "@const/*": ["src/constants/*"],
      "@core/*": ["src/core/*"],
      "@postcss/*": ["src/postcss/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
